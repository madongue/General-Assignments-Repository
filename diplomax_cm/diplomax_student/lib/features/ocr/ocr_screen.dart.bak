import 'package:flutter/material.dart';
import 'package:go_router/go_router.dart';
import 'package:google_fonts/google_fonts.dart';
import '../../utils/app_colors.dart';

class OcrScreen extends StatefulWidget {
  const OcrScreen({super.key});
  @override State<OcrScreen> createState() => _OcrScreenState();
}

class _OcrScreenState extends State<OcrScreen> with SingleTickerProviderStateMixin {
  late AnimationController _ctrl;
  _OcrState _state = _OcrState.idle;

  final Map<String, String> _extracted = {};

  @override
  void initState() {
    super.initState();
    _ctrl = AnimationController(vsync: this, duration: const Duration(seconds: 2))..repeat();
  }

  @override void dispose() { _ctrl.dispose(); super.dispose(); }

  Future<void> _scan() async {
    setState(() { _state = _OcrState.scanning; _extracted.clear(); });
    // Simulate OCR processing stages
    await Future.delayed(const Duration(milliseconds: 800));
    setState(() => _state = _OcrState.processing);
    await Future.delayed(const Duration(milliseconds: 1400));
    setState(() {
      _state = _OcrState.done;
      _extracted.addAll({
        'Nom complet':      'BASSA Joëlle Sandrine',
        'Matricule':        'ICT/2021/0849',
        'Diplôme':          'Licence en Génie Logiciel',
        'Université':       'The ICT University',
        'Mention':          'Bien',
        'Année':            '2024',
        'N° de diplôme':    'ICT-LIC-2024-0849',
      });
    });
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: AppColors.background,
      appBar: AppBar(
        leading: BackButton(onPressed: () => context.go('/home')),
        title: Text('Scanner OCR', style: GoogleFonts.instrumentSerif(fontSize: 22)),
      ),
      body: SingleChildScrollView(
        padding: const EdgeInsets.all(20),
        child: Column(
          children: [
            // Info banner
            Container(
              padding: const EdgeInsets.all(14),
              decoration: BoxDecoration(
                color: AppColors.warningLight,
                borderRadius: BorderRadius.circular(12),
                border: Border.all(color: AppColors.warning.withOpacity(0.2)),
              ),
              child: Row(
                children: [
                  const Icon(Icons.document_scanner_rounded, color: AppColors.warning, size: 18),
                  const SizedBox(width: 10),
                  Expanded(
                    child: Text(
                      'Scannez un diplôme ou relevé papier pour en extraire automatiquement les informations.',
                      style: GoogleFonts.dmSans(fontSize: 12, color: AppColors.warning, height: 1.5),
                    ),
                  ),
                ],
              ),
            ),
            const SizedBox(height: 24),

            // Camera preview placeholder
            GestureDetector(
              onTap: _state == _OcrState.idle ? _scan : null,
              child: Container(
                height: 260,
                decoration: BoxDecoration(
                  color: Colors.black,
                  borderRadius: BorderRadius.circular(20),
                  border: Border.all(
                    color: _state == _OcrState.done
                        ? AppColors.success
                        : AppColors.border,
                    width: _state == _OcrState.done ? 2 : 1,
                  ),
                ),
                child: Stack(
                  children: [
                    // Grid overlay
                    ClipRRect(
                      borderRadius: BorderRadius.circular(20),
                      child: CustomPaint(
                        painter: _GridPainter(),
                        child: Container(),
                      ),
                    ),
                    // Scan line animation
                    if (_state == _OcrState.scanning)
                      AnimatedBuilder(
                        animation: _ctrl,
                        builder: (_, __) => Positioned(
                          top: _ctrl.value * 240,
                          left: 20, right: 20,
                          child: Container(
                            height: 2,
                            decoration: BoxDecoration(
                              gradient: LinearGradient(colors: [
                                Colors.transparent,
                                AppColors.accent.withOpacity(0.8),
                                Colors.transparent,
                              ]),
                            ),
                          ),
                        ),
                      ),
                    // Center content
                    Center(
                      child: _buildCameraCenter(),
                    ),
                    // Corners
                    ..._buildCorners(),
                  ],
                ),
              ),
            ),

            const SizedBox(height: 20),

            // Status / Actions
            if (_state == _OcrState.idle) ...[
              ElevatedButton.icon(
                icon: const Icon(Icons.camera_alt_rounded, size: 18),
                label: const Text('Prendre une photo du document'),
                onPressed: _scan,
              ),
              const SizedBox(height: 10),
              OutlinedButton.icon(
                icon: const Icon(Icons.photo_library_rounded, size: 18),
                label: const Text('Importer depuis la galerie'),
                onPressed: _scan,
              ),
            ],

            if (_state == _OcrState.processing) ...[
              const SizedBox(height: 8),
              _processingCard(),
            ],

            if (_state == _OcrState.done && _extracted.isNotEmpty) ...[
              const SizedBox(height: 8),
              _extractedCard(context),
            ],
          ],
        ),
      ),
    );
  }

  Widget _buildCameraCenter() {
    switch (_state) {
      case _OcrState.idle:
        return Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            const Icon(Icons.document_scanner_rounded, color: Colors.white54, size: 48),
            const SizedBox(height: 10),
            Text('Appuyez pour scanner', style: GoogleFonts.dmSans(color: Colors.white54, fontSize: 13)),
          ],
        );
      case _OcrState.scanning:
        return Text('Scan en cours...', style: GoogleFonts.dmSans(color: AppColors.accent, fontSize: 13));
      case _OcrState.processing:
        return Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            const CircularProgressIndicator(color: AppColors.accent, strokeWidth: 2),
            const SizedBox(height: 12),
            Text('Analyse OCR...', style: GoogleFonts.dmSans(color: Colors.white70, fontSize: 13)),
          ],
        );
      case _OcrState.done:
        return Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            const Icon(Icons.check_circle_rounded, color: AppColors.success, size: 48),
            const SizedBox(height: 8),
            Text('Extraction réussie', style: GoogleFonts.dmSans(color: AppColors.success, fontSize: 13, fontWeight: FontWeight.w500)),
          ],
        );
    }
  }

  Widget _processingCard() {
    final steps = ['Détection du document', 'Correction perspective', 'Extraction du texte', 'Vérification des champs'];
    return Container(
      padding: const EdgeInsets.all(16),
      decoration: BoxDecoration(
        color: AppColors.surface,
        borderRadius: BorderRadius.circular(14),
        border: Border.all(color: AppColors.border),
      ),
      child: Column(
        children: steps.asMap().entries.map((e) {
          return Padding(
            padding: const EdgeInsets.symmetric(vertical: 5),
            child: Row(
              children: [
                SizedBox(
                  width: 18,
                  height: 18,
                  child: CircularProgressIndicator(strokeWidth: 1.5, color: AppColors.primary.withOpacity(0.5 + e.key * 0.15)),
                ),
                const SizedBox(width: 12),
                Text(e.value, style: GoogleFonts.dmSans(fontSize: 13, color: AppColors.textSecondary)),
              ],
            ),
          );
        }).toList(),
      ),
    );
  }

  Widget _extractedCard(BuildContext ctx) {
    return Container(
      padding: const EdgeInsets.all(16),
      decoration: BoxDecoration(
        color: AppColors.surface,
        borderRadius: BorderRadius.circular(16),
        border: Border.all(color: AppColors.success.withOpacity(0.3)),
      ),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          Row(
            children: [
              const Icon(Icons.auto_awesome_rounded, color: AppColors.success, size: 18),
              const SizedBox(width: 8),
              Text('Données extraites par OCR', style: GoogleFonts.dmSans(fontSize: 14, fontWeight: FontWeight.w500)),
              const Spacer(),
              Container(
                padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 3),
                decoration: BoxDecoration(color: AppColors.primaryLight, borderRadius: BorderRadius.circular(6)),
                child: Text('${_extracted.length} champs', style: GoogleFonts.dmSans(fontSize: 10, color: AppColors.primary, fontWeight: FontWeight.w500)),
              ),
            ],
          ),
          const SizedBox(height: 12),
          const Divider(height: 1, color: AppColors.divider),
          const SizedBox(height: 10),
          ..._extracted.entries.map((e) => Padding(
            padding: const EdgeInsets.symmetric(vertical: 5),
            child: Row(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                SizedBox(
                  width: 110,
                  child: Text(e.key, style: GoogleFonts.dmSans(fontSize: 11, color: AppColors.textSecondary, fontWeight: FontWeight.w300)),
                ),
                Expanded(
                  child: Text(e.value, style: GoogleFonts.dmSans(fontSize: 12, fontWeight: FontWeight.w500)),
                ),
              ],
            ),
          )),
          const SizedBox(height: 14),
          ElevatedButton.icon(
            icon: const Icon(Icons.save_rounded, size: 16),
            label: const Text('Enregistrer dans le coffre-fort'),
            onPressed: () {
              ScaffoldMessenger.of(ctx).showSnackBar(SnackBar(
                content: Text('Document ajouté au coffre-fort !', style: GoogleFonts.dmSans()),
                backgroundColor: AppColors.success,
                behavior: SnackBarBehavior.floating,
                shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(10)),
              ));
            },
          ),
        ],
      ),
    );
  }

  List<Widget> _buildCorners() {
    const c = AppColors.accent;
    const s = 28.0;
    const t = 2.5;
    return [
      Positioned(top: 16, left: 16, child: _corner(c, s, t, true, true)),
      Positioned(top: 16, right: 16, child: _corner(c, s, t, true, false)),
      Positioned(bottom: 16, left: 16, child: _corner(c, s, t, false, true)),
      Positioned(bottom: 16, right: 16, child: _corner(c, s, t, false, false)),
    ];
  }

  Widget _corner(Color c, double s, double t, bool top, bool left) => Container(
    width: s, height: s,
    decoration: BoxDecoration(
      border: Border(
        top:    top  ? BorderSide(color: c, width: t) : BorderSide.none,
        bottom: !top ? BorderSide(color: c, width: t) : BorderSide.none,
        left:   left  ? BorderSide(color: c, width: t) : BorderSide.none,
        right:  !left ? BorderSide(color: c, width: t) : BorderSide.none,
      ),
    ),
  );
}

enum _OcrState { idle, scanning, processing, done }

class _GridPainter extends CustomPainter {
  @override
  void paint(Canvas canvas, Size size) {
    final paint = Paint()
      ..color = Colors.white.withOpacity(0.04)
      ..strokeWidth = 0.5;
    for (double x = 0; x < size.width; x += 40) {
      canvas.drawLine(Offset(x, 0), Offset(x, size.height), paint);
    }
    for (double y = 0; y < size.height; y += 40) {
      canvas.drawLine(Offset(0, y), Offset(size.width, y), paint);
    }
  }
  @override bool shouldRepaint(_) => false;
}
