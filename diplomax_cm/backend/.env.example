# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false

# ── Database (auto-configured in Docker Compose) ──────────────────────────────
POSTGRES_USER=diplomax
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/diplomax
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ── SECURITY — generate these with: openssl rand -hex 64 ──────────────────────
JWT_SECRET_KEY=CHANGE_ME_USE_A_RANDOM_64_CHAR_HEX_SECRET
MASTER_AES_KEY_HEX=CHANGE_ME_USE_A_RANDOM_64_CHAR_HEX_SECRET
DEFAULT_ICT_ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
DEFAULT_STUDENT_PASSWORD=CHANGE_ME_STRONG_STUDENT_PASSWORD

# ── MTN MoMo — get from https://momodeveloper.mtn.com ─────────────────────────
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
MTN_MOMO_ENVIRONMENT=sandbox

# ── Orange Money — get from https://developer.orange.com ──────────────────────
ORANGE_MONEY_CLIENT_ID=
ORANGE_MONEY_CLIENT_SECRET=
ORANGE_MONEY_MERCHANT_KEY=

# ── Hyperledger Fabric — URL of your Fabric REST gateway ──────────────────────
FABRIC_GATEWAY_URL=http://fabric-gateway:8080

# ── Firebase — download from Firebase Console → Project Settings → Service Accounts
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json

# ── Google Cloud Vision OCR — download from Google Cloud Console ──────────────
GOOGLE_APPLICATION_CREDENTIALS=/app/google-credentials.json

# ── S3 Object Storage (MinIO locally, or AWS S3 / Scaleway in prod) ───────────
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=CHANGE_ME_S3_ACCESS_KEY
S3_SECRET_KEY=CHANGE_ME_S3_SECRET_KEY
